# =============================================================================
# ASR Environment Configuration
# =============================================================================
# This file contains NON-SENSITIVE configuration for local development.
# ALL SECRETS (passwords, API keys, Neo4j credentials) are stored in Infisical.
#
# To use: Copy to .env and fill in Infisical credentials
# =============================================================================

# -----------------------------------------------------------------------------
# Infisical Connection (Secret Store)
# -----------------------------------------------------------------------------
INFISICAL_HOST=http://localhost:3000
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

# Infisical Project IDs
INFISICAL_CORE_PROJECT_ID=31ce7b6b-24ac-441f-ae3e-d47a13719238
INFISICAL_ASR_PROJECT_ID=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
