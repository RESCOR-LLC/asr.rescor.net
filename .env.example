# =============================================================================
# ASR Environment Configuration — Infisical Bootstrap ONLY
# =============================================================================
# This file contains ONLY the credentials needed to connect to Infisical
# (the secrets store).  ALL runtime configuration (Neo4j URIs, passwords,
# ports) is loaded from Infisical at startup via @rescor/core-config.
#
# To use: rescor env deploy asr.rescor.net
# =============================================================================

# -----------------------------------------------------------------------------
# Infisical Connection (Secret Store Bootstrap)
# -----------------------------------------------------------------------------
INFISICAL_HOST=http://localhost:3000
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

# ASR Infisical project (created via rescor store initialize asr.rescor.net)
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
